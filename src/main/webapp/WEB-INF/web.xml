<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Morix — 3 Men's Morris</display-name>

  <!--
    DB config fallbacks — used when context.xml JNDI is unavailable.
    On Render, DATABASE_URL env var takes priority (parsed in DB.java).
    When running on Tomcat locally with context.xml, JNDI is used instead.
  -->
  <context-param>
    <param-name>db.url</param-name>
    <param-value>jdbc:postgresql://localhost:5432/morix</param-value>
  </context-param>
  <context-param>
    <param-name>db.user</param-name>
    <param-value>morix_user</param-value>
  </context-param>
  <context-param>
    <param-name>db.password</param-name>
    <param-value>morix_pass</param-value>
  </context-param>

  <!-- Bootstrap: init DB on startup -->
  <listener>
    <listener-class>com.morix.util.AppContextListener</listener-class>
  </listener>

  <!-- Serve index.html for root -->
  <servlet>
    <servlet-name>IndexServlet</servlet-name>
    <servlet-class>com.morix.servlet.IndexServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>IndexServlet</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>

  <!-- Leaderboard REST endpoint — AJAX -->
  <servlet>
    <servlet-name>LeaderboardServlet</servlet-name>
    <servlet-class>com.morix.servlet.LeaderboardServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LeaderboardServlet</servlet-name>
    <url-pattern>/api/leaderboard</url-pattern>
  </servlet-mapping>

  <!-- Game History REST endpoint — AJAX -->
  <servlet>
    <servlet-name>HistoryServlet</servlet-name>
    <servlet-class>com.morix.servlet.HistoryServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HistoryServlet</servlet-name>
    <url-pattern>/api/history</url-pattern>
  </servlet-mapping>

  <!-- Player Profile REST endpoint — AJAX -->
  <servlet>
    <servlet-name>ProfileServlet</servlet-name>
    <servlet-class>com.morix.servlet.ProfileServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ProfileServlet</servlet-name>
    <url-pattern>/api/profile</url-pattern>
  </servlet-mapping>

  <!-- Health check -->
  <servlet>
    <servlet-name>HealthServlet</servlet-name>
    <servlet-class>com.morix.servlet.HealthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HealthServlet</servlet-name>
    <url-pattern>/api/health</url-pattern>
  </servlet-mapping>

  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>
</web-app>
